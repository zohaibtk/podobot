ENVIRONMENT=production
API_PREFIX=/api
ENABLE_OPENAPI=false

DATABASE_URL_OVERRIDE=postgresql+psycopg://postgres.rybbvzssnnnluqfiwqbe:YOUR_DATABASE_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_POOL_SIZE=1
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_RECYCLE_SECONDS=300

CORS_ORIGINS=https://your-podobot-frontend.vercel.app
CORS_ORIGIN_REGEX=

REDIS_URL=rediss://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379/0
CELERY_RESULT_BACKEND_URL=rediss://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379/1

LOCAL_STORAGE_ROOT=/tmp/podobot-storage
MAX_UPLOAD_BYTES=10485760

AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_DEV_ADMIN_PASSWORD=replace-with-a-strong-admin-password
BUFFER_WEBHOOK_SECRET=replace-with-a-long-random-secret
SECRETS_ENCRYPTION_KEY=replace-with-a-long-random-secret-if-you-use-encrypted-provider-secrets

OPENAI_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-nano,gpt-4-turbo,gpt-4,gpt-3.5-turbo,o4-mini,o3-mini,o3,o1
OPENAI_API_BASE_URL=https://api.openai.com/v1
GEMINI_MODEL=gemini-2.5-flash
GROK_MODEL=grok-latest
GROQ_MODEL=llama-3.3-70b-versatile
