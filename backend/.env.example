APP_NAME=PodoBot API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api
ENABLE_OPENAPI=true
CORS_ORIGINS=["http://localhost:5173"]
CORS_ORIGIN_REGEX=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=podobot
POSTGRES_USER=podobot
POSTGRES_PASSWORD=podobot
DATABASE_URL_OVERRIDE=
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_RECYCLE_SECONDS=3600

REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND_URL=redis://localhost:6379/1

LOCAL_STORAGE_ROOT=.local/storage
MAX_UPLOAD_BYTES=5368709120

SECRETS_ENCRYPTION_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-nano,gpt-4-turbo,gpt-4,gpt-3.5-turbo,o4-mini,o3-mini,o3,o1
OPENAI_API_BASE_URL=https://api.openai.com/v1
GEMINI_MODEL=gemini-2.5-flash
GROK_MODEL=grok-latest
GROQ_MODEL=llama-3.3-70b-versatile

LOG_LEVEL=INFO
